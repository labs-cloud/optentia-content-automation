# Copy to .env and fill in. These are PUBLIC (read at JS-bundle time).

# The API origin (no trailing slash) — the Vercel deployment that has the
# bypass flag set (a branch Preview).
EXPO_PUBLIC_API_BASE_URL=https://optentia-content-automation.vercel.app

# --- Temporary dev bypass (no login). Set to 1 to skip sign-in and load the
#     owner's data. The matching server flag in Vercel is DEV_AUTH_BYPASS=1.
EXPO_PUBLIC_DEV_BYPASS=1

# --- Optional: real Clerk login instead (set DEV_BYPASS above to 0/blank).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
