# Copy to .env and fill in. These are PUBLIC (read at JS-bundle time).

# The API origin (no trailing slash). For the dev bypass, use the Vercel
# deployment that has the bypass env var set (a branch Preview, or prod).
EXPO_PUBLIC_API_BASE_URL=https://optentia-content-automation.vercel.app

# --- Option A: temporary dev bypass (no login, no Clerk key needed) ---
# Set this to the SAME random string you set as DEV_AUTH_BYPASS_TOKEN in the
# Vercel deployment above. The app skips sign-in and loads the owner's data.
EXPO_PUBLIC_DEV_BYPASS_TOKEN=

# --- Option B: real Clerk login (leave bypass blank to use this) ---
# The same publishable key your web app uses (safe to expose).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
